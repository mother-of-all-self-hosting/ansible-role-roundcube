TZ={{ roundcube_environment_variables_tz }}

ROUNDCUBEMAIL_DEFAULT_HOST={{ roundcube_environment_variables_default_imap_host }}
{% if roundcube_environment_variables_default_imap_port != '' %}
ROUNDCUBEMAIL_DEFAULT_PORT={{ roundcube_environment_variables_default_imap_port }}
{% endif %}

ROUNDCUBEMAIL_SMTP_SERVER={{ roundcube_environment_variables_smtp_server }}
{% if roundcube_environment_variables_smtp_port != '' %}
ROUNDCUBEMAIL_SMTP_PORT={{ roundcube_environment_variables_smtp_port }}
{% endif %}

{% if roundcube_database_type == 'mysql' %}
ROUNDCUBEMAIL_DB_TYPE=mysql
ROUNDCUBEMAIL_DB_HOST={{ roundcube_database_environment_variables_database_host_mysql }}
ROUNDCUBEMAIL_DB_PORT={{ roundcube_database_mysql_port }}
ROUNDCUBEMAIL_DB_USER={{ roundcube_database_mysql_username }}
ROUNDCUBEMAIL_DB_PASSWORD={{ roundcube_database_mysql_password }}
ROUNDCUBEMAIL_DB_NAME={{ roundcube_database_name }}
{% elif roundcube_database_type == 'postgres' %}
ROUNDCUBEMAIL_DB_TYPE=pgsql
ROUNDCUBEMAIL_DB_HOST={{ roundcube_database_environment_variables_database_host_postgres }}
ROUNDCUBEMAIL_DB_PORT={{ roundcube_database_postgres_port }}
ROUNDCUBEMAIL_DB_USER={{ roundcube_database_postgres_username }}
ROUNDCUBEMAIL_DB_PASSWORD={{ roundcube_database_postgres_password }}
ROUNDCUBEMAIL_DB_NAME={{ roundcube_database_name }}
{% elif roundcube_database_type == 'sqlite' %}
ROUNDCUBEMAIL_DB_TYPE=sqlite
{% endif %}

{% if roundcube_environment_variables_plugins != '' %}
ROUNDCUBEMAIL_PLUGINS={{ roundcube_environment_variables_plugins }}
{% endif %}

{% if roundcube_environment_variables_upload_max_filesize != '' and roundcube_variant != 'apache-nonroot' %}
ROUNDCUBEMAIL_UPLOAD_MAX_FILESIZE={{ roundcube_environment_variables_upload_max_filesize }}
{% endif %}

{% if roundcube_environment_variables_aspell_dicts != '' and roundcube_variant != 'apache-nonroot' %}
ROUNDCUBEMAIL_ASPELL_DICTS={{ roundcube_environment_variables_aspell_dicts }}
{% endif %}

{{ roundcube_environment_variables_additional_variables }}
